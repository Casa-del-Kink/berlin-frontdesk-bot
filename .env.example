# Copy this file to .env and fill in the values.

# --- OpenRouter (LLM) ---
OPENROUTER_API_KEY=replace_with_openrouter_key
# Model: pick one from https://openrouter.ai/models . If this slug fails, try
# "anthropic/claude-3.5-haiku" or "anthropic/claude-3.5-sonnet".
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# --- Twilio WhatsApp (sandbox for the demo) ---
# https://console.twilio.com -> Messaging -> Try it out -> WhatsApp sandbox
TWILIO_ACCOUNT_SID=replace_with_twilio_account_sid
TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
# Twilio sandbox number (don't change unless you have your own number)
TWILIO_WHATSAPP_FROM=whatsapp:+14100000000
# Public base URL used for Twilio signature validation, e.g. https://abc.ngrok-free.app
TWILIO_WEBHOOK_BASE_URL=
# Local-only escape hatch. Keep false/empty in production.
SKIP_TWILIO_SIGNATURE_VALIDATION=false

# --- Google Calendar ---
# Paste the Service Account JSON on a SINGLE line (see README).
GOOGLE_SA_JSON={"type":"service_account","project_id":"replace_me"}
# Credential-free local test mode. Keep false/empty in production.
USE_FAKE_CALENDAR=false
FAKE_CALENDAR_FILE=data/fake-calendar.json

# --- Shared server tool endpoints (ElevenLabs / internal tools) ---
# If set, POST /tools/:name requires an Authorization bearer header.
SERVER_TOOL_TOKEN=replace_with_random_long_token
# Optional. Distinct owner-only token for /operator/* routes (pause, resume, alert-test).
# Falls back to SERVER_TOOL_TOKEN when unset. Recommended for production so the
# voice-agent/server-tool token cannot drive operator actions.
OPERATOR_TOKEN=
# Hours a conversation stays paused after a human-handoff request before the bot resumes
# automatically. Must be a positive number.
HANDOFF_PAUSE_HOURS=4

# --- Business (client) ---
# Config file of the business to serve.
CLIENT_FILE=clients/salon-demo.yaml
STATE_FILE=data/state.json
# json for local demos/tests; postgres for production/multi-worker pilots.
STORE_BACKEND=json
# Required when STORE_BACKEND=postgres. Do not commit a real value.
# Tilda dev Supabase direct connection template:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.dicxsxmdyjleigelwaya.supabase.co:5432/postgres
DATABASE_URL=postgres://user:***@localhost:5432/berlin_frontdesk
# Optional Supabase admin REST API client. Server-only; never expose the secret key to clients.
# Use a Supabase secret API key (sb_secret_...). It is sent on the apikey header, not Authorization.
SUPABASE_URL=https://dicxsxmdyjleigelwaya.supabase.co
SUPABASE_SECRET_KEY=replace_with_supabase_secret_key
# Optional helper for npm run supabase:postgres:smoke. Do not commit a real value.
SUPABASE_PROJECT_REF=dicxsxmdyjleigelwaya
SUPABASE_DB_PASSWORD=replace_with_supabase_db_password
# Set PGSSL=true for hosted Supabase/Neon Postgres providers that require TLS.
PGSSL=true
MAX_HISTORY_PER_PHONE=50
# Used by POST /privacy/retention/purge when maxAgeDays is omitted. Endpoint dry-runs by default.
DATA_RETENTION_DAYS=90
# Internal hosted demos can accept console-only owner alerts when ownerWhatsapp is intentionally empty.
# Leave false for client pilots; configure ownerWhatsapp in the client YAML instead.
OWNER_ALERT_LOG_ONLY_ACCEPTED=false
# Set true only after AVV/DPA/subprocessor review for live vendors is complete.
COMPLIANCE_DPA_REVIEWED=false
# Only required (blocker) when the active client YAML sets dataSensitivity: health
# (dental/medical/§203 StGB scope). Set true only after a full subprocessor-by-
# subprocessor legal/vendor review — see wiki/decisions/2026-07-01-subprocessor-review-triggers.md.
COMPLIANCE_SUBPROCESSOR_REVIEW_COMPLETE=false
# Set true only when all /readiness/live-pilot blockers are resolved; startup will fail otherwise.
REQUIRE_LIVE_PILOT_READINESS=false
PORT=3000

# --- Test-only fixtures (never set these in a live deployment) ---
# CALCOM_TEST_ATTENDEE_EMAIL, CALCOM_KEEP_SMOKE_BOOKING, and FORCE_WHATSAPP_SEND_FAILURE are
# smoke-test fixtures. If any is set, /readiness/live-pilot fails closed with a
# "test fixtures absent" blocker so a leftover test var can never reach live customer traffic.
