{
  "name": "berlin-frontdesk-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI front-desk over WhatsApp for Berlin businesses (demo). WhatsApp (Twilio) + Claude via OpenRouter + Google Calendar.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "check": "tsx src/check.ts",
    "style:guard": "python3 scripts/check-style-guard.py",
    "first-test:smoke": "tsx src/first-test.ts",
    "google-calendar:smoke": "tsx src/google-calendar-smoke.ts",
    "live-calendar:smoke": "tsx src/live-calendar-booking-smoke.ts",
    "postgres:smoke": "tsx src/postgres-store-smoke.ts",
    "supabase:postgres:smoke": "bash scripts/supabase-postgres-smoke.sh",
    "supabase:admin:smoke": "tsx src/supabase-admin-smoke.ts",
    "server:battletest": "tsx src/server-battletest.ts",
    "voice:smoke": "tsx src/voice-agent-tool-smoke.ts",
    "voice:contract": "tsx src/elevenlabs-agent-contract.ts",
    "voice:contract:smoke": "tsx src/voice-agent-contract-smoke.ts",
    "voice:post-call:smoke": "tsx src/voice-post-call-smoke.ts",
    "owner-alert:smoke": "tsx src/owner-alert-failure-smoke.ts",
    "demo:fake": "tsx src/fake-provider-demo.ts",
    "deployment:preflight": "tsx src/deployment-preflight.ts",
    "deployment:preflight:smoke": "tsx src/deployment-preflight-smoke.ts",
    "deployment:smoke": "tsx src/deployment-smoke.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^173.0.0",
    "js-yaml": "^4.1.0",
    "luxon": "^3.5.0",
    "node-cron": "^4.5.0",
    "openai": "^4.67.0",
    "pg": "^8.13.1",
    "twilio": "^5.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.7.4",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
